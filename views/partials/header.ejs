<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <a href="/" class="brand">
      <img src="<%= site.logo %>" alt="MAP Logo" class="brand-logo">
      <span class="brand-text">
        <span class="brand-name">MAP Kellergalerie</span>
        <span class="brand-sub">Montafoner Artgenossen Plattform</span>
      </span>
    </a>
    <nav class="main-nav" id="mainNav" aria-label="Hauptnavigation">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Start</a>
      <a href="/ueber-uns" class="<%= currentPath === '/ueber-uns' ? 'active' : '' %>">Über uns</a>
      <a href="/ausstellungen" class="<%= currentPath.startsWith('/ausstellungen') ? 'active' : '' %>">Ausstellungen</a>
      <a href="/publikationen" class="<%= currentPath === '/publikationen' ? 'active' : '' %>">Publikationen</a>
      <a href="/sponsoren" class="<%= currentPath === '/sponsoren' ? 'active' : '' %>">Sponsoren</a>
      <a href="/kontakt" class="<%= currentPath === '/kontakt' ? 'active' : '' %>">Kontakt</a>
      <% if (site.sommerbar) { %><a href="<%= site.sommerbar %>" target="_blank" rel="noopener" class="nav-ext">Sommerbar ↗</a><% } %>
    </nav>
    <button class="nav-toggle" id="navToggle" aria-label="Menü öffnen" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
