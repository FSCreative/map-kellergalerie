<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<%
var pageTitle = title ? title + ' | ' + site.siteName : site.siteName + ' – Galerie in Schruns, Montafon';
var pageDesc = site.metaDescription;
var ogImage = site.heroImage;
var ogType = 'website';
var isExhibition = (typeof ex !== 'undefined') && ex;
if (isExhibition) {
  ogType = 'article';
  if (ex.images && ex.images.length) ogImage = ex.images[0];
  var d = 'Ausstellung in der MAP Kellergalerie in Schruns im Montafon';
  if (ex.subtitle) d = ex.subtitle + ' – ' + d;
  if (ex.body && ex.body.length) d += '. ' + ex.body[0];
  pageDesc = ex.title + ': ' + d;
} else if (currentPath === '/ausstellungen') {
  pageDesc = 'Alle Ausstellungen und Veranstaltungen der MAP Kellergalerie in Schruns im Montafon – Malerei, Fotografie, Druckgraphik, Lesungen, Konzerte und mehr.';
} else if (currentPath === '/ueber-uns') {
  pageDesc = 'Die Geschichte der MAP Kellergalerie in Schruns: seit 1999 Kunst im Montafon. Lernen Sie den Verein Montafoner Artgenossen Plattform und unser Team kennen.';
} else if (currentPath === '/publikationen') {
  pageDesc = 'Bücher und Kataloge der MAP Kellergalerie – Publikationen zu Ausstellungen und Künstler:innen, erhältlich auf Anfrage.';
} else if (currentPath === '/kontakt') {
  pageDesc = 'Kontakt und Öffnungszeiten der MAP Kellergalerie, Bahnhofstraße 12, 6780 Schruns. ' + site.openingHours;
} else if (currentPath === '/sponsoren') {
  pageDesc = 'Unsere Sponsoren und Unterstützer – sie machen die Ausstellungen der MAP Kellergalerie möglich.';
}
pageDesc = String(pageDesc).slice(0, 160);
var canonical = baseUrl + currentPath;
var absUrl = function (u) { return u && u.indexOf('http') === 0 ? u : baseUrl + u; };
%>
<title><%= pageTitle %></title>
<meta name="description" content="<%= pageDesc %>">
<% if (currentPath.indexOf('/admin') === 0) { %><meta name="robots" content="noindex, nofollow"><% } %>
<link rel="canonical" href="<%= canonical %>">
<link rel="icon" type="image/jpeg" href="<%= site.logo %>">
<meta property="og:site_name" content="<%= site.siteName %>">
<meta property="og:locale" content="de_AT">
<meta property="og:type" content="<%= ogType %>">
<meta property="og:url" content="<%= canonical %>">
<meta property="og:title" content="<%= pageTitle %>">
<meta property="og:description" content="<%= pageDesc %>">
<meta property="og:image" content="<%= absUrl(ogImage) %>">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= pageTitle %>">
<meta name="twitter:description" content="<%= pageDesc %>">
<meta name="twitter:image" content="<%= absUrl(ogImage) %>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ArtGallery",
  "name": "<%= site.siteName %>",
  "alternateName": "<%= site.orgName %>",
  "url": "<%= baseUrl %>",
  "image": "<%= absUrl(site.heroImage) %>",
  "logo": "<%= absUrl(site.logo) %>",
  "email": "<%= site.email %>",
  "telephone": "<%= site.phone %>",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bahnhofstraße 12",
    "postalCode": "6780",
    "addressLocality": "Schruns",
    "addressRegion": "Vorarlberg",
    "addressCountry": "AT"
  },
  "sameAs": ["<%= site.facebook %>"],
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Friday", "Saturday", "Sunday"],
    "opens": "17:00",
    "closes": "19:00"
  }]
}
</script>
<% if (isExhibition) { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ExhibitionEvent",
  "name": <%- JSON.stringify(ex.title) %>,
  "startDate": "<%= ex.date %>",
  "url": "<%= canonical %>",
  "image": <%- JSON.stringify(absUrl(ogImage)) %>,
  "description": <%- JSON.stringify(pageDesc) %>,
  "location": {
    "@type": "Place",
    "name": "MAP Kellergalerie",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Bahnhofstraße 12",
      "postalCode": "6780",
      "addressLocality": "Schruns",
      "addressCountry": "AT"
    }
  }
}
</script>
<% } %>
</head>
<body>
