<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-col">
      <h4><%= site.siteName %></h4>
      <p><%= site.orgName %></p>
      <p><%= site.address %></p>
      <p>ZVR-Zahl: <%= site.zvr %></p>
    </div>
    <div class="footer-col">
      <h4>Kontakt</h4>
      <p><a href="mailto:<%= site.email %>"><%= site.email %></a></p>
      <p><a href="tel:<%= site.phone.replace(/\s/g,'') %>"><%= site.phone %></a></p>
      <p><a href="<%= site.facebook %>" target="_blank" rel="noopener">Facebook ↗</a></p>
    </div>
    <div class="footer-col">
      <h4>Öffnungszeiten</h4>
      <p><%= site.openingHours %></p>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© <%= new Date().getFullYear() %> <%= site.siteName %></span>
    <span class="footer-admin">
      <% if (isAdmin) { %>
        <a href="/admin">Admin-Bereich</a> ·
        <form method="post" action="/admin/logout" class="inline-form"><button type="submit" class="linklike">Abmelden</button></form>
      <% } else { %>
        <a href="/admin/login">Admin</a>
      <% } %>
    </span>
  </div>
</footer>
<nav class="tabbar" aria-label="Mobile Navigation">
  <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/></svg>
    <span>Start</span>
  </a>
  <a href="/ausstellungen" class="<%= currentPath.indexOf('/ausstellungen') === 0 ? 'active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="m3 15 5-5 4 4 3-3 6 6"/><circle cx="9" cy="8.5" r="1.3"/></svg>
    <span>Ausstellungen</span>
  </a>
  <a href="/publikationen" class="<%= currentPath === '/publikationen' ? 'active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20V3H6.5A2.5 2.5 0 0 0 4 5.5v14Z"/><path d="M4 19.5A2.5 2.5 0 0 0 6.5 22H20v-5"/></svg>
    <span>Publikationen</span>
  </a>
  <a href="/ueber-uns" class="<%= currentPath === '/ueber-uns' ? 'active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.5"/><path d="M2.5 20c.8-3.2 3.4-5 6.5-5s5.7 1.8 6.5 5"/><path d="M16 4.6a3.5 3.5 0 0 1 0 6.8"/><path d="M18.2 15.4c1.7.7 2.9 2 3.3 4.6"/></svg>
    <span>Über uns</span>
  </a>
  <a href="/kontakt" class="<%= currentPath === '/kontakt' ? 'active' : '' %>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
    <span>Kontakt</span>
  </a>
</nav>
<div class="lightbox" id="lightbox" hidden>
  <button class="lb-close" aria-label="Schließen">×</button>
  <button class="lb-prev" aria-label="Vorheriges Bild">‹</button>
  <img src="" alt="">
  <button class="lb-next" aria-label="Nächstes Bild">›</button>
  <div class="lb-caption"></div>
</div>
<script src="/js/main.js?v=<%= typeof assetV !== 'undefined' ? assetV : 1 %>"></script>
</body>
</html>
