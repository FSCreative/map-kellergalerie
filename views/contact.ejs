<%- include('partials/head') %>
<%- include('partials/header') %>
<main>
  <section class="page-head">
    <div class="container">
      <h1 class="reveal">Kontakt</h1>
      <p class="lead reveal">Sie möchten uns erreichen? Wir freuen uns auf Ihre Nachricht.</p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container split">
      <div class="contact-info reveal">
        <h2>MAP Kellergalerie</h2>
        <p><%= site.address %></p>
        <p><a href="mailto:<%= site.email %>"><%= site.email %></a></p>
        <p><a href="tel:<%= site.phone.replace(/\s/g,'') %>"><%= site.phone %></a></p>
        <p class="mt"><strong>Öffnungszeiten</strong><br><%= site.openingHours %></p>
        <a href="https://maps.google.com/?q=<%= encodeURIComponent(site.address) %>" target="_blank" rel="noopener" class="btn btn-dark">Auf Karte anzeigen ↗</a>
      </div>
      <form class="contact-form reveal" id="contactForm">
        <div class="form-row">
          <label>Name<input type="text" name="name" required></label>
          <label>E-Mail-Adresse<input type="email" name="email" required></label>
        </div>
        <label>Betreff<input type="text" name="subject" required></label>
        <label>Nachricht<textarea name="message" rows="6" required></textarea></label>
        <button type="submit" class="btn btn-dark">Nachricht senden</button>
        <p class="form-hint">Beim Absenden öffnet sich Ihr E-Mail-Programm mit der fertigen Nachricht an <%= site.email %>.</p>
      </form>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
