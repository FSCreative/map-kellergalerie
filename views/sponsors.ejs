<%- include('partials/head') %>
<%- include('partials/header') %>
<main>
  <section class="page-head">
    <div class="container">
      <h1 class="reveal">Sponsoren</h1>
      <p class="lead reveal"><%= site.sponsorsIntro %></p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      <p class="section-kicker center reveal">Danke für die Unterstützung</p>
      <div class="sponsor-grid">
        <% sponsors.forEach((s, i) => { %>
        <div class="sponsor-card reveal" style="transition-delay: <%= i * 60 %>ms">
          <img src="<%= s.image %>" alt="<%= s.name || 'Sponsor-Logo' %>" loading="lazy">
        </div>
        <% }) %>
      </div>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
